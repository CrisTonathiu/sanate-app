generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  NUTRITIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
}

enum AllergySeverity {
  LOW
  MEDIUM
  HIGH
  SEVERE
}

enum MealType {
  SMOOTHIE
  BREAKFAST
  SNACK
  LUNCH
  DINNER
  DRINKS
}

enum ProtocolStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  firstName      String
  lastName       String
  phone          String?
  whatsappNumber String?
  role           UserRole @default(PATIENT)

  // Multi-tenant (si habrá varias nutriólogas)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Relaciones
  nutritionistPatients Patient[]      @relation("NutritionistPatients")
  patientProfile       Patient?       @relation("UserPatient")
  consultations        Consultation[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  lastLoginAt DateTime?
  isActive    Boolean   @default(true)

  @@index([role])
}

model Patient {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("UserPatient", fields: [userId], references: [id])

  nutritionistId String
  nutritionist   User   @relation("NutritionistPatients", fields: [nutritionistId], references: [id])

  birthDate     DateTime?
  gender        Gender    @default(MALE)
  height        Float?
  initialWeight Float?

  vitals        PatientVital[]
  conditions    PatientCondition[]
  allergies     PatientAllergy[]
  notes         PatientNote[]
  consultations Consultation[]
  protocols     Protocol[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PatientVital {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  weightKg          Float?
  bodyFatPercentage Float?
  muscleMassKg      Float?

  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  heartRate              Int?

  glucoseMgDl     Float?
  cholesterolMgDl Float?

  recordedAt DateTime @default(now())
}

model Condition {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  patients PatientCondition[]

  createdAt DateTime @default(now())
}

model PatientCondition {
  id          String @id @default(cuid())
  patientId   String
  conditionId String

  patient   Patient   @relation(fields: [patientId], references: [id])
  condition Condition @relation(fields: [conditionId], references: [id])

  diagnosedAt DateTime?
  notes       String?

  createdAt DateTime @default(now())
}

model Allergen {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  patients PatientAllergy[]

  createdAt DateTime @default(now())
}

model PatientAllergy {
  id         String @id @default(cuid())
  patientId  String
  allergenId String

  patient  Patient  @relation(fields: [patientId], references: [id])
  allergen Allergen @relation(fields: [allergenId], references: [id])

  severity AllergySeverity?
  notes    String?

  createdAt DateTime @default(now())
}

model PatientNote {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  title   String?
  content String

  createdAt DateTime @default(now())
}

model Recipe {
  id           String  @id @default(cuid())
  title        String

  mealType MealType

  ingredients   RecipeIngredient[]
  extraIngredients RecipeExtraIngredient[]
  steps RecipeStep[]
  protocolMeals ProtocolMeal[]

  createdAt DateTime @default(now())
}

model RecipeStep {
  id String @id @default(cuid())

  recipeId String
  stepNumber Int
  instruction String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, stepNumber])
  @@index([recipeId])
}

model RecipeExtraIngredient {
  id String @id @default(cuid())

  recipeId String
  name String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([recipeId])
}

model Ingredient {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  foodId String?
  food   Food?   @relation(fields: [foodId], references: [id])

  recipes RecipeIngredient[]
}

model RecipeIngredient {
  id String @id @default(cuid())

  recipeId     String
  ingredientId String

  grams Float

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
}

model ProtocolWeek {
  id         String @id @default(cuid())
  protocolId String
  weekNumber Int

  protocol Protocol @relation(fields: [protocolId], references: [id])

  days ProtocolDay[]
}

model ProtocolDay {
  id       String @id @default(cuid())
  weekId   String
  dayIndex Int

  week ProtocolWeek @relation(fields: [weekId], references: [id])

  meals ProtocolMeal[]
}

model ProtocolMeal {
  id String @id @default(cuid())

  dayId    String
  mealType MealType

  recipeId String?

  day    ProtocolDay @relation(fields: [dayId], references: [id])
  recipe Recipe?     @relation(fields: [recipeId], references: [id])
}

model Protocol {
  id String @id @default(cuid())

  title     String
  weekCount Int

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  status ProtocolStatus @default(ACTIVE)

  weeksPlan ProtocolWeek[]
  revisions ProtocolRevision[]

  createdAt DateTime @default(now())
}

model ProtocolRevision {
  id String @id @default(cuid())

  protocolId String
  protocol   Protocol @relation(fields: [protocolId], references: [id])

  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])

  createdAt DateTime @default(now())
}

model Consultation {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  nutritionistId String
  nutritionist   User   @relation(fields: [nutritionistId], references: [id])

  reason    String?
  diagnosis String?
  treatment String?
  notes     String?

  followUpAt DateTime?
  revisions  ProtocolRevision[]

  createdAt DateTime @default(now())
}

// This would be like "1 equivalencia de arroz = 30g", para facilitar la creación de recetas y protocolos sin tener que calcular cada vez las equivalencias.
model Food {
  id   String @id @default(cuid())
  name String

  groupId String
  group   FoodGroup @relation(fields: [groupId], references: [id])

  // 🔥 macros por 100g (estándar nutrición)
  proteinPer100g Float?
  carbsPer100g   Float?
  fatPer100g     Float?
  caloriesPer100g Float?

  // opcional
  density Float? // útil para líquidos

  equivalents FoodEquivalent[]
  equivalentIn FoodEquivalent[] @relation("EquivalentFood")

  ingredients Ingredient[]

  createdAt DateTime @default(now())
}

model FoodEquivalent {
  id String @id @default(cuid())

  foodId String
  food   Food @relation(fields: [foodId], references: [id])

  equivalentFoodId String
  equivalentFood   Food @relation("EquivalentFood", fields: [equivalentFoodId], references: [id])

  // 🔥 cantidad equivalente
  grams Float

  // opcional: para UI
  displayText String? // "10 camarones" o "1 lata"

  createdAt DateTime @default(now())

  @@index([foodId])
}

// This would be like "Vegetales", "Frutas", "Cereales", etc. to categorizar los alimentos y facilitar la búsqueda.
model FoodGroup {
  id   String @id @default(cuid())
  name String

  isFree Boolean @default(false)

  foods Food[]
}

model ProtocolFoodGroup {
  id String @id @default(cuid())

  protocolId String
  groupId    String

  totalEquivalents Float

  breakfast Float
  snack     Float
  lunch     Float
  dinner    Float
}

// Organización a la que pertenecen los usuarios (nutriólogas y pacientes) para SaaS futuro.
model Organization {
  id    String @id @default(cuid())
  name  String
  users User[]

  createdAt DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  NUTRITIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
}

enum AllergySeverity {
  LOW
  MEDIUM
  HIGH
  SEVERE
}

enum MealType {
  BREAKFAST
  SNACK
  LUNCH
  DINNER
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String
  lastName        String
  phone           String?
  whatsappNumber  String?
  role            UserRole  @default(PATIENT)

  // Multi-tenant (si habrá varias nutriólogas)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  // Relaciones
  nutritionistPatients  Patient[]      @relation("NutritionistPatients")
  patientProfile        Patient?       @relation("UserPatient")
  consultations         Consultation[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  lastLoginAt DateTime?
  isActive    Boolean @default(true)

  @@index([role])
}

model Patient {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation("UserPatient", fields: [userId], references: [id])

  nutritionistId  String
  nutritionist    User     @relation("NutritionistPatients", fields: [nutritionistId], references: [id])

  birthDate       DateTime?
  gender          Gender @default(MALE)
  height          Float?
  initialWeight   Float?

  vitals          PatientVital[]
  conditions      PatientCondition[]
  allergies       PatientAllergy[]
  notes           PatientNote[]
  consultations   Consultation[]
  protocols       Protocol[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PatientVital {
  id                       String   @id @default(cuid())
  patientId                String
  patient                  Patient  @relation(fields: [patientId], references: [id])

  weightKg                 Float?
  bodyFatPercentage        Float?
  muscleMassKg             Float?

  bloodPressureSystolic    Int?
  bloodPressureDiastolic   Int?
  heartRate                Int?

  glucoseMgDl              Float?
  cholesterolMgDl          Float?

  recordedAt               DateTime @default(now())
}

model Condition {
  id    String @id @default(cuid())
  name  String @unique

  patients PatientCondition[]
}

model PatientCondition {
  id          String   @id @default(cuid())
  patientId   String
  conditionId String

  patient     Patient   @relation(fields: [patientId], references: [id])
  condition   Condition @relation(fields: [conditionId], references: [id])

  diagnosedAt DateTime?
  notes       String?

  createdAt   DateTime @default(now())
}

model Allergen {
  id   String @id @default(cuid())
  name String @unique
  description String?

  patients PatientAllergy[]
  
  createdAt  DateTime @default(now())
}

model PatientAllergy {
  id         String   @id @default(cuid())
  patientId  String
  allergenId String

  patient    Patient  @relation(fields: [patientId], references: [id])
  allergen   Allergen @relation(fields: [allergenId], references: [id])

  severity   AllergySeverity?
  notes      String?

  createdAt  DateTime @default(now())
}

model PatientNote {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])

  title      String?
  content    String

  createdAt  DateTime @default(now())
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  instructions String

  mealType    MealType

  ingredients RecipeIngredient[]
  protocolMeals ProtocolMeal[]

  createdAt   DateTime @default(now())
}

model Ingredient {
  id   String @id @default(cuid())
  name String @unique

  recipes RecipeIngredient[]
  baseEquivalents       IngredientEquivalent[] @relation("IngredientBase")
  equivalentIngredients IngredientEquivalent[] @relation("IngredientEquivalent")
}

model RecipeIngredient {
  id           String @id @default(cuid())

  recipeId     String
  ingredientId String

  quantity     Float?
  unit         String?

  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model IngredientEquivalent {
  id String @id @default(cuid())

  ingredientId String
  equivalentId String

  ingredient Ingredient @relation("IngredientBase", fields: [ingredientId], references: [id])
  equivalent Ingredient @relation("IngredientEquivalent", fields: [equivalentId], references: [id])
}

model ProtocolWeek {
  id         String @id @default(cuid())
  protocolId String
  weekNumber Int

  protocol Protocol @relation(fields: [protocolId], references: [id])

  days ProtocolDay[]
}

model ProtocolDay {
  id       String @id @default(cuid())
  weekId   String
  dayIndex Int

  week ProtocolWeek @relation(fields: [weekId], references: [id])

  meals ProtocolMeal[]
}

model ProtocolMeal {
  id String @id @default(cuid())

  dayId String
  mealType MealType

  recipeId String?

  day ProtocolDay @relation(fields: [dayId], references: [id])
  recipe Recipe? @relation(fields: [recipeId], references: [id])
}

model Protocol {
  id String @id @default(cuid())

  title String

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])

  isTemplate Boolean @default(false)

  weekCount Int
  weeks ProtocolWeek[]

  createdAt DateTime @default(now())
}

model Consultation {
  id          String   @id @default(cuid())

  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])

  nutritionistId String
  nutritionist   User @relation(fields: [nutritionistId], references: [id])

  reason      String?
  diagnosis   String?
  treatment   String?

  notes       String?

  followUpAt  DateTime?

  protocols   Protocol[]

  createdAt   DateTime @default(now())
}

// Organización a la que pertenecen los usuarios (nutriólogas y pacientes) para SaaS futuro.
model Organization {
  id        String  @id @default(cuid())
  name      String
  users     User[]

  createdAt DateTime @default(now())
}
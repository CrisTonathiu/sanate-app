generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  NUTRITIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
}

enum AllergySeverity {
  LOW
  MEDIUM
  HIGH
  SEVERE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String
  lastName        String
  phone           String?
  whatsappNumber  String?
  role            UserRole  @default(PATIENT)

  // Multi-tenant (si habrá varias nutriólogas)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  // Relaciones
  nutritionistPatients  Patient[]      @relation("NutritionistPatients")
  patientProfile        Patient?       @relation("UserPatient")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  lastLoginAt DateTime?
  isActive    Boolean @default(true)

  @@index([role])
}

model Patient {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation("UserPatient", fields: [userId], references: [id])

  nutritionistId  String
  nutritionist    User     @relation("NutritionistPatients", fields: [nutritionistId], references: [id])

  birthDate       DateTime?
  gender          Gender @default(MALE)
  height          Float?
  initialWeight   Float?

  vitals          PatientVital[]
  conditions      PatientCondition[]
  allergies       PatientAllergy[]
  notes           PatientNote[]
  consultations   Consultation[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PatientVital {
  id                       String   @id @default(cuid())
  patientId                String
  patient                  Patient  @relation(fields: [patientId], references: [id])

  weightKg                 Float?
  bodyFatPercentage        Float?
  muscleMassKg             Float?

  bloodPressureSystolic    Int?
  bloodPressureDiastolic   Int?
  heartRate                Int?

  glucoseMgDl              Float?
  cholesterolMgDl          Float?

  recordedAt               DateTime @default(now())
}

model PatientCondition {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])

  name       String   // "Diabetes Type 2", "Hypertension"
  diagnosedAt DateTime?
  notes      String?

  createdAt  DateTime @default(now())
}

model PatientAllergy {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])

  allergen   String   // "Peanuts", "Lactose", "Seafood"
  severity   AllergySeverity?
  notes      String?

  createdAt  DateTime @default(now())
}

model PatientNote {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])

  title      String?
  content    String

  createdAt  DateTime @default(now())
}

model Consultation {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])

  reason      String?
  diagnosis   String?
  treatment   String?
  followUpAt  DateTime?

  createdAt   DateTime @default(now())
}

// Organización a la que pertenecen los usuarios (nutriólogas y pacientes) para SaaS futuro.
model Organization {
  id        String  @id @default(cuid())
  name      String
  users     User[]

  createdAt DateTime @default(now())
}